# Twitch API — https://dev.twitch.tv/console
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Bot OAuth — https://twitchapps.com/tmi/
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_BOT_OAUTH=oauth:your_oauth_token_here

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create OAuth Client ID (Web application)
# Authorized JavaScript origins: http://localhost:8080 (or your domain)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email of the first admin (auto-whitelisted + promoted on first login)
ADMIN_EMAIL=your.email@gmail.com

# Database
POSTGRES_USER=twitchmod
POSTGRES_PASSWORD=twitchmod_secret
POSTGRES_DB=twitchmod

# App
NODE_ENV=production
JWT_SECRET=change_me_to_random_string
CORS_ORIGIN=http://localhost:3000

# Frontend (build-time)
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# === Telegram bot (optional) ===
# 1. Talk to @BotFather in Telegram, /newbot, get token
# 2. Send any message to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
